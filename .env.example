# ============================================
# DATABASE (PostgreSQL)
# ============================================
POSTGRES_USER=rezervari_user
POSTGRES_PASSWORD=schimba_aceasta_parola
POSTGRES_DB=rezervari_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string folosit de SQLAlchemy + psycopg
DATABASE_URL=postgresql+psycopg://rezervari_user:schimba_aceasta_parola@localhost:5432/rezervari_db

# ============================================
# JWT / AUTENTIFICARE
# ============================================
# Genereaza un secret lung si random.
# In PowerShell: [System.Convert]::ToBase64String((1..48 | % {Get-Random -Maximum 256}))
JWT_SECRET_KEY=inlocuieste_cu_un_secret_random_de_minim_32_caractere
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# REDIS (cache si rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Rezervari Terenuri Sportive

# ============================================
# OAUTH (Google) - se completeaza in etapa de autentificare
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ============================================
# STRIPE (test mode) - se completeaza in etapa de plati
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# APLICATIE
# ============================================
APP_ENV=development
DEBUG=True
TIMEZONE=Europe/Bucharest
